-- package.json --
{
  "name": "lovelylark",
  "version": "1.0.0",
  "type": "module",
  "description": "Chrome extension to copy product cards from grocery sites",
  "scripts": {
    "build": "shx rm -rf dist && shx mkdir -p dist && pnpm run build:all && pnpm run copy:assets",
    "build:all": "pnpm run build:content && pnpm run build:popup",
    "build:content": "vite build --config vite.content.config.ts",
    "build:popup": "vite build --config vite.popup.config.ts",
    "copy:assets": "shx cp src/manifest.json src/popup/popup.html src/popup/popup.css dist/",
    "dev": "pnpm run build && pnpm run build:content -- --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.323",
    "jsdom": "^27.3.0",
    "shx": "^0.3.4",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "vite-plugin-checker": "^0.9.1",
    "vitest": "^3.1.4"
  }
}
-- src/content/content.ts --
import { siteConfigs, urlExtractors } from "@shared/stores"
import { createProductCardCopier } from "@shared/copier"

const copier = createProductCardCopier(siteConfigs, urlExtractors)
copier.init()
-- src/manifest.json --
{
  "manifest_version": 3,
  "name": "Lovelylark",
  "version": "1.0.0",
  "description": "Copy product cards from grocery sites with x + click",
  "permissions": ["clipboardWrite", "storage"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Lovelylark Settings"
  },
  "content_scripts": [
    {
      "matches": ["*://*.target.com/*", "*://*.wholefoodsmarket.com/*", "*://*.amazon.com/*", "*://seattle.lamsseafood.com/*", "*://*.safeway.com/*", "*://*.qfc.com/*", "*://*.fredmeyer.com/*", "*://*.hmart.com/*", "*://*.pccmarkets.com/*", "*://*.instacart.com/*", "*://*.traderjoes.com/*", "*://*.walmart.com/*", "*://*.chefstore.com/*", "*://shop.groceryoutlet.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
