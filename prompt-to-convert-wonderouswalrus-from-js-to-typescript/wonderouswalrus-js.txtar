-- app.js --
document.addEventListener("DOMContentLoaded", function () {
  // Initialize application
  const stores = StoreFactory.createStores()
  const searchService = new SearchService(stores)
  const configService = new ConfigurationService()
  const uiController = new UIController(searchService, configService)
})
-- controllers/UIController.js --
class UIController {
  constructor(searchService, configService) {
    this.searchService = searchService
    this.configService = configService
    this.searchInput = document.getElementById("searchInput")
    this.openAllBtn = document.getElementById("openAllBtn")
    this.storesContainer = document.getElementById("storesContainer")
    this.storeBtnTemplate = document.getElementById("storeBtnTemplate")
    this.configSelect = document.getElementById("configSelect")
    this.zeroBtn = document.getElementById("zeroBtn")
    this.saveConfigBtn = document.getElementById("saveConfigBtn")
    this.deleteConfigBtn = document.getElementById("deleteConfigBtn")
    this.storeDelays = {}
    this.initialize()
  }

  initialize() {
    // Get last search term from localStorage or use default
    const lastSearchTerm = localStorage.getItem("lastSearchTerm") || "romaine lettuce"
    this.searchInput.value = lastSearchTerm
    // Populate configuration dropdown first
    this.populateConfigurationSelect()
    // Load the last used configuration
    this.loadLastUsedConfiguration()
    // Create store buttons
    this.createStoreButtons()

    // Set up event listeners
    this.setupEventListeners()

    // Focus and select the search input text
    this.searchInput.focus()
    this.searchInput.select()
  }
  loadLastUsedConfiguration() {
    const lastConfigName = this.configService.getCurrentConfigurationName()

    if (lastConfigName === "custom") {
      // For custom config, check if we have a saved custom config in the service
      const customConfig = this.configService.getCustomConfiguration()
      if (customConfig) {
        this.storeDelays = { ...customConfig.delays }
      } else {
        this.setDefaultDelays()
      }
    } else {
      // Load the saved configuration
      const config = this.configService.getConfiguration(lastConfigName)
      if (config) {
        this.storeDelays = { ...config.delays }
      } else {
        // Configuration doesn't exist anymore, fall back to custom with defaults
        this.setDefaultDelays()
        this.configService.setCurrentConfigurationName("custom")
      }
    }

    // Set the select to show the current config
    this.configSelect.value = this.configService.getCurrentConfigurationName()
  }
  setDefaultDelays() {
    const defaultDelays = {
      "H Mart": 0,
      Walmart: 0,
      "Trader Joe's": 0,
      Uwajimaya: 0,
      Target: 0,
      Meijer: 0,
      "Lam's Seafood": 0,
      "Fred Meyer": 0,
      QFC: 0,
      Amazon: 0,
      Safeway: 0,
      "PCC Markets": 0,
      "Whole Foods": 0,
      "Grocery Outlet": 0,
      "Central Co-op": 0,
      "Chef Store": 0,
      Costco: 0,
    }
    this.storeDelays = { ...defaultDelays }
    this.configService.saveCustomConfiguration(this.storeDelays)
  }
  zeroAllDelays() {
    // Set all delays to 0
    Object.keys(this.storeDelays).forEach((storeName) => {
      this.storeDelays[storeName] = 0
    })

    // Save to the current configuration
    const currentConfig = this.configService.getCurrentConfigurationName()
    if (currentConfig === "custom") {
      this.configService.saveCustomConfiguration(this.storeDelays)
    } else {
      this.configService.saveConfiguration(currentConfig, this.storeDelays)
    }

    // Update all delay inputs
    this.updateDelayInputs()
  }
  populateConfigurationSelect() {
    const configs = this.configService.getAllConfigurations()
    const currentConfig = this.configService.getCurrentConfigurationName()

    // Clear existing options except "Custom"
    this.configSelect.innerHTML = '<option value="custom">Custom</option>'

    // Add saved configurations
    configs.forEach((config) => {
      const option = document.createElement("option")
      option.value = config.name
      option.textContent = config.name
      this.configSelect.appendChild(option)
    })

    // Set the current configuration
    this.configSelect.value = currentConfig
  }
  createStoreButtons() {
    this.searchService.stores.forEach((store) => {
      const btnClone = this.storeBtnTemplate.content.cloneNode(true)
      const storeItem = btnClone.querySelector(".store-item")
      const storeBtn = btnClone.querySelector(".store-btn")
      const delayInput = btnClone.querySelector(".delay-input")

      storeBtn.textContent = store.name
      storeBtn.dataset.storeName = store.name

      // Set delay input value from stored delays
      delayInput.value = this.storeDelays[store.name] || 0
      delayInput.dataset.storeName = store.name

      this.storesContainer.appendChild(btnClone)
    })
  }

  setupEventListeners() {
    // Individual store button clicks
    this.storesContainer.addEventListener("click", (e) => {
      if (e.target.classList.contains("store-btn")) {
        const storeName = e.target.dataset.storeName
        const store = this.searchService.stores.find((s) => s.name === storeName)
        if (store) {
          this.searchService.searchSingleStore(store, this.getSearchTerm())
        }
      }
    })

    // Open all button click
    this.openAllBtn.addEventListener("click", () => {
      this.searchService.searchAllStores(this.getSearchTerm(), this.storeDelays)
    })

    // Delay input changes
    this.storesContainer.addEventListener("change", (e) => {
      if (e.target.classList.contains("delay-input")) {
        const storeName = e.target.dataset.storeName
        const delay = parseInt(e.target.value)

        // Validate and update the store delay
        if (!isNaN(delay) && delay >= 0) {
          this.storeDelays[storeName] = delay
          // Save to current configuration
          const currentConfig = this.configService.getCurrentConfigurationName()
          if (currentConfig === "custom") {
            this.configService.saveCustomConfiguration(this.storeDelays)
          } else {
            this.configService.saveConfiguration(currentConfig, this.storeDelays)
          }
        } else {
          // Reset to default if invalid
          e.target.value = this.storeDelays[storeName]
        }
      }
    })
    // Configuration select change
    this.configSelect.addEventListener("change", (e) => {
      const configName = e.target.value
      if (configName === "custom") {
        // Load custom configuration
        const customConfig = this.configService.getCustomConfiguration()
        if (customConfig) {
          this.storeDelays = { ...customConfig.delays }
        } else {
          this.setDefaultDelays()
        }
        this.configService.setCurrentConfigurationName("custom")
        this.updateDelayInputs()
      } else {
        // Load the selected configuration
        const config = this.configService.getConfiguration(configName)
        if (config) {
          this.storeDelays = { ...config.delays }
          this.configService.setCurrentConfigurationName(configName)
          // Update all delay inputs
          this.updateDelayInputs()
        }
      }
    })
    // Zero all button
    this.zeroBtn.addEventListener("click", () => {
      this.zeroAllDelays()
    })
    // Save configuration button
    this.saveConfigBtn.addEventListener("click", () => {
      const configName = prompt("Enter a name for this configuration:")
      if (configName && configName.trim() && configName.toLowerCase() !== "custom") {
        this.configService.saveConfiguration(configName.trim(), this.storeDelays)
        this.populateConfigurationSelect()
        this.configSelect.value = configName.trim()
      }
    })
    // Delete configuration button
    this.deleteConfigBtn.addEventListener("click", () => {
      const configName = this.configSelect.value
      if (configName !== "custom") {
        this.configService.deleteConfiguration(configName)
        this.populateConfigurationSelect()
        this.configSelect.value = "custom"
      }
    })
  }
  updateDelayInputs() {
    const delayInputs = this.storesContainer.querySelectorAll(".delay-input")
    delayInputs.forEach((input) => {
      const storeName = input.dataset.storeName
      input.value = this.storeDelays[storeName] || 0
    })
  }

  getSearchTerm() {
    const term = this.searchInput.value.trim()
    if (!term) {
      return ""
    }
    return term
  }
}
