// Custom implementation for H Mart
class HMartStore extends Store {
  constructor() {
    // Pass null as we'll override the URL generation
    super("H Mart", null)
  }

  // Override to implement custom behavior for H Mart
  getUrl(searchTerm) {
    const encodedTerm = encodeURIComponent(searchTerm)
    return `https://www.hmart.com/${encodedTerm}?_q=${encodedTerm}&map=ft`
  }
}
-- models/Store.js --
// Base Store class
class Store {
  constructor(name, searchUrlTemplate) {
    this.name = name
    this.searchUrlTemplate = searchUrlTemplate
  }

  getUrl(searchTerm) {
    return this.searchUrlTemplate.replace("{term}", encodeURIComponent(searchTerm))
  }

  // Method that can be overridden by specialized store classes
  processSearch(searchTerm) {
    const url = this.getUrl(searchTerm)
    return { url, openMethod: "standard" }
  }
}
-- script.js --
document.addEventListener("DOMContentLoaded", function () {
  // Base Store class
  class Store {
    constructor(name, searchUrlTemplate) {
      this.name = name
      this.searchUrlTemplate = searchUrlTemplate
    }

    getUrl(searchTerm) {
      return this.searchUrlTemplate.replace("{term}", encodeURIComponent(searchTerm))
    }

    // Method that can be overridden by specialized store classes
    processSearch(searchTerm) {
      const url = this.getUrl(searchTerm)
      return { url, openMethod: "standard" }
    }
  }
  // Custom store implementations can extend the base Store class
  class HMartStore extends Store {
    constructor() {
      // Pass null as we'll override the URL generation
      super("H Mart", null)
    }

    // Override to implement custom behavior for H Mart
    getUrl(searchTerm) {
      const encodedTerm = encodeURIComponent(searchTerm)
      return `https://www.hmart.com/${encodedTerm}?_q=${encodedTerm}&map=ft`
    }
  }

  // Store Factory - centralizes creation of store instances
  class StoreFactory {
    static createStores() {
      const standardStores = [
        new Store("Walmart", "https://www.walmart.com/search?q={term}"),
        new Store("Trader Joe's", "https://www.traderjoes.com/home/search?q={term}"),
        new Store("Uwajimaya", "https://www.uwajimaya.com/?s={term}"),
        new Store("Target", "https://www.target.com/s?searchTerm={term}"),
        new Store(
          "Lam's Seafood",
          "https://seattle.lamsseafood.com/search?filter%5Btext%5D={term}",
        ),
        new Store("Fred Meyer", "https://www.fredmeyer.com/search?query={term}"),
        new Store("QFC", "https://www.qfc.com/search?query={term}"),
        new Store("Amazon", "https://www.amazon.com/s?k={term}"),
        new Store("Safeway", "https://www.safeway.com/shop/search-results.html?q={term}"),
        new Store("Whole Foods", "https://www.wholefoodsmarket.com/search?text={term}"),
        new Store(
          "PCC Markets",
          "https://delivery.pccmarkets.com/store/pcc-community-markets/s?k={term}",
        ),
      ]
      // Add any specialized store implementations
      const specializedStores = [new HMartStore()]
      return [...standardStores, ...specializedStores]
    }
  }
  // SearchService - handles the search operations
  class SearchService {
    constructor(stores) {
      this.stores = stores
    }

    searchSingleStore(store, searchTerm) {
      if (!searchTerm) {
        throw new Error("Search term required")
      }
      const result = store.processSearch(searchTerm)
      this.openWindow(result.url, result.openMethod, result.data)
    }
    searchAllStores(searchTerm) {
      if (!searchTerm) {
        throw new Error("Search term required")
      }
      this.stores.forEach((store, index) => {
        setTimeout(() => {
          const result = store.processSearch(searchTerm)
          this.openWindow(result.url, result.openMethod, result.data)
        }, index * 50) // Add a small delay to avoid popup blocking
      })
    }
    openWindow(url, method = "standard", data = null) {
      if (method === "standard") {
        window.open(url, "_blank")
      } else if (method === "custom") {
        // Example of custom window opening behavior
        const newWindow = window.open(url, "_blank", "width=800,height=600")
        if (newWindow) newWindow.focus()
      } else if (method === "post") {
        // Handle POST request by creating a form and submitting it
        this.submitPostForm(url, data)
      }
      // Can add more opening methods as needed
    }

    submitPostForm(url, data) {
      // Create a temporary form element
      const form = document.createElement("form")
      form.method = "POST"
      form.action = url
      form.target = "_blank"

      // Add form fields for each data property
      if (data) {
        Object.keys(data).forEach((key) => {
          const input = document.createElement("input")
          input.type = "hidden"
          input.name = key
          input.value = data[key]
          form.appendChild(input)
        })
      }

      // Add the form to the document, submit it, and remove it
      document.body.appendChild(form)
      form.submit()
      document.body.removeChild(form)
    }
  }
  // UI Controller - manages the interface
  class UIController {
    constructor(searchService) {
      this.searchService = searchService
      this.searchInput = document.getElementById("searchInput")
      this.openAllBtn = document.getElementById("openAllBtn")
      this.storesContainer = document.getElementById("storesContainer")
      this.storeBtnTemplate = document.getElementById("storeBtnTemplate")
      this.initialize()
    }
    initialize() {
      // Set default search term
      this.searchInput.value = "romaine lettuce"
      // Create store buttons
      this.createStoreButtons()
      // Set up event listeners
      this.setupEventListeners()
    }
    createStoreButtons() {
      this.searchService.stores.forEach((store) => {
        const btnClone = this.storeBtnTemplate.content.cloneNode(true)
        const storeBtn = btnClone.querySelector(".store-btn")
        storeBtn.textContent = store.name
        storeBtn.dataset.storeName = store.name
        this.storesContainer.appendChild(btnClone)
      })
    }
    setupEventListeners() {
      // Individual store button clicks
      this.storesContainer.addEventListener("click", (e) => {
        if (e.target.classList.contains("store-btn")) {
          const storeName = e.target.dataset.storeName
          const store = this.searchService.stores.find((s) => s.name === storeName)
          if (store) {
            try {
              this.searchService.searchSingleStore(store, this.getSearchTerm())
            } catch (error) {
              alert(error.message)
            }
          }
        }
      })
      // Open all button click
      this.openAllBtn.addEventListener("click", () => {
        try {
          this.searchService.searchAllStores(this.getSearchTerm())
        } catch (error) {
          alert(error.message)
        }
      })
    }
    getSearchTerm() {
      const term = this.searchInput.value.trim()
      if (!term) {
        throw new Error("Please enter a search term")
      }
      return term
    }
  }
  // Application initialization
  const stores = StoreFactory.createStores()
  const searchService = new SearchService(stores)
  const uiController = new UIController(searchService)
})
-- services/ConfigurationService.js --
class ConfigurationService {
  constructor() {
    this.storageKey = "delayConfigurations"
    this.currentConfigKey = "currentConfiguration"
    this.customConfigKey = "customConfiguration"
  }
  getAllConfigurations() {
    const saved = localStorage.getItem(this.storageKey)
    return saved ? JSON.parse(saved) : []
  }
  getConfiguration(name) {
    const configs = this.getAllConfigurations()
    return configs.find((c) => c.name === name)
  }
  getCustomConfiguration() {
    const saved = localStorage.getItem(this.customConfigKey)
    return saved ? JSON.parse(saved) : null
  }
  saveCustomConfiguration(delays) {
    const config = {
      name: "custom",
      delays: { ...delays },
    }
    localStorage.setItem(this.customConfigKey, JSON.stringify(config))
  }
  saveConfiguration(name, delays) {
    const configs = this.getAllConfigurations()
    const existingIndex = configs.findIndex((c) => c.name === name)
    const newConfig = {
      name: name,
      delays: { ...delays },
    }
    if (existingIndex >= 0) {
      configs[existingIndex] = newConfig
    } else {
      configs.push(newConfig)
    }
    localStorage.setItem(this.storageKey, JSON.stringify(configs))
    this.setCurrentConfigurationName(name)
  }
  deleteConfiguration(name) {
    const configs = this.getAllConfigurations()
    const filtered = configs.filter((c) => c.name !== name)
    localStorage.setItem(this.storageKey, JSON.stringify(filtered))
    // If we deleted the current config, reset to custom
    if (this.getCurrentConfigurationName() === name) {
      this.setCurrentConfigurationName("custom")
    }
  }
  getCurrentConfigurationName() {
    return localStorage.getItem(this.currentConfigKey) || "custom"
  }
  setCurrentConfigurationName(name) {
    localStorage.setItem(this.currentConfigKey, name)
  }
}
-- services/LamsSeafoodStore.js --
class LamsSeafoodStore extends Store {
  constructor() {
    super("Lam's Seafood", "https://seattle.lamsseafood.com/search")
  }
  processSearch(searchTerm) {
    // Encode the search term to base64
    const encodedTerm = btoa(searchTerm)
    // Build URL with base64 encoded etext parameter and widget parameter
    const url = `${this.searchUrlTemplate}?filter%5Betext%5D=${encodedTerm}&filter%5Bwidget%5D=1`
    return {
      url: url,
      openMethod: "standard",
    }
  }
}
-- services/SearchService.js --
class SearchService {
  constructor(stores) {
    this.stores = stores
  }

  searchSingleStore(store, searchTerm) {
    if (!searchTerm) {
      return
    }

    // Save the search term to localStorage
    localStorage.setItem("lastSearchTerm", searchTerm)

    const result = store.processSearch(searchTerm)
    this.openWindow(result.url, result.openMethod, result.data)
  }

  searchAllStores(searchTerm, storeDelays) {
    if (!searchTerm) {
      return
    }

    // Save the search term to localStorage
    localStorage.setItem("lastSearchTerm", searchTerm)

    console.log("=== Starting searchAllStores ===")
    console.log("Search term:", searchTerm)
    console.log("Store delays:", storeDelays)

    // Create an array of stores with their delays
    const storesWithDelays = this.stores.map((store) => ({
      store: store,
      delay: storeDelays[store.name] || 0,
    }))

    console.log(
      "Stores before sorting:",
      storesWithDelays.map((s) => `${s.store.name}: ${s.delay}s`),
    )

    // Sort by delay (shortest to longest)
    storesWithDelays.sort((a, b) => a.delay - b.delay)

    console.log(
      "Stores after sorting:",
      storesWithDelays.map((s) => `${s.store.name}: ${s.delay}s`),
    )

    // Calculate cumulative delays
    let cumulativeDelay = 0

    console.log("=== Scheduling stores ===")
    // Open windows in order of delay time
    storesWithDelays.forEach((item, index) => {
      const scheduleTime = cumulativeDelay // Capture current value before it changes!
      console.log(
        `[${index}] Scheduling ${item.store.name} to open at ${scheduleTime}s (delay: ${item.delay}s)`,
      )

      setTimeout(() => {
        console.log(`[${index}] OPENING ${item.store.name} now (scheduled for ${scheduleTime}s)`)
        const result = item.store.processSearch(searchTerm)
        this.openWindow(result.url, result.openMethod, result.data)
      }, scheduleTime * 1000) // Use the captured value

      // Add this store's delay to the cumulative delay
      cumulativeDelay += item.delay
      console.log(`   Cumulative delay is now: ${cumulativeDelay}s`)
    })

    console.log("=== All stores scheduled ===")
    console.log(`Total time to open all stores: ${cumulativeDelay}s`)
  }

  openWindow(url, method = "standard", data = null) {
    if (method === "standard") {
      window.open(url, "_blank")
    } else if (method === "custom") {
      // Example of custom window opening behavior
      const newWindow = window.open(url, "_blank", "width=800,height=600")
      if (newWindow) newWindow.focus()
    } else if (method === "post") {
      // Handle POST request by creating a form and submitting it
      this.submitPostForm(url, data)
    }
    // Can add more opening methods as needed
  }

  submitPostForm(url, data) {
    // Create a temporary form element
    const form = document.createElement("form")
    form.method = "POST"
    form.action = url
    form.target = "_blank"

    // Add form fields for each data property
    if (data) {
      Object.keys(data).forEach((key) => {
        const input = document.createElement("input")
        input.type = "hidden"
        input.name = key
        input.value = data[key]
        form.appendChild(input)
      })
    }

    // Add the form to the document, submit it, and remove it
    document.body.appendChild(form)
    form.submit()
    document.body.removeChild(form)
  }
}
