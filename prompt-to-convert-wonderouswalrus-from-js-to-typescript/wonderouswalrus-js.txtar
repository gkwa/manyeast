<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Grocery Store Search</title>
    <link rel="stylesheet" href="styles.css" />
  </head>
  <body>
    <div class="container">
      <h1>Grocery Store Search</h1>
      <div class="search-container">
        <input
          type="text"
          id="searchInput"
          placeholder="Enter search term (e.g., romaine lettuce)"
        />
        <button id="openAllBtn">Open All Stores</button>
      </div>
      <div class="config-container">
        <label for="configSelect">Configuration:</label>
        <select id="configSelect">
          <option value="custom">Custom</option>
        </select>
        <button id="zeroBtn">Zero All</button>
        <button id="saveConfigBtn">Save Config</button>
        <button id="deleteConfigBtn">Delete Config</button>
      </div>
      <div class="stores-container" id="storesContainer">
        <template id="storeBtnTemplate">
          <div class="store-item">
            <button class="store-btn"></button>
            <div class="store-delay">
              <label>Delay (s):</label>
              <input type="number" class="delay-input" min="0" value="0" />
            </div>
          </div>
        </template>
      </div>
    </div>
    <!-- Model classes -->
    <script src="models/Store.js"></script>
    <script src="models/HMartStore.js"></script>
    <!-- Services -->
    <script src="services/ConfigurationService.js"></script>
    <script src="services/SearchService.js"></script>
    <!-- Specialized Store Implementations -->
    <script src="services/LamsSeafoodStore.js"></script>
    <!-- Factory -->
    <script src="services/StoreFactory.js"></script>
    <!-- Controllers -->
    <script src="controllers/UIController.js"></script>
    <!-- Main Application -->
    <script src="app.js"></script>
  </body>
</html>
